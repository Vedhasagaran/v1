---
import Layout from '@/layouts/Layout.astro';
import Providers from '@/components/layout/Providers';
import ProjectsList from '@/components/sections/ProjectsList';
import Footer from '@/components/layout/Footer';
import { projects } from '@/data/projectsData';
---

<Layout
  title="Projects - Vedhasagaran"
  description="Explore software engineering projects, open source tools, and systems designed by Vedhasagaran."
>
  <Providers client:only="react" skills={[]} />

  <div class="max-w-4xl mx-auto px-6 pt-36 pb-16 flex flex-col gap-16 items-center justify-center w-full">
    <div class="w-full">
      <ProjectsList projects={projects} client:load />
    </div>
  </div>

  <Footer />
</Layout>
