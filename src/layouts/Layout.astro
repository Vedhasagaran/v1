---
import { ClientRouter } from 'astro:transitions';
import { ASSETS } from '@/data/assets';
import '../styles/global.css';

export interface Props {
  title: string;
  description?: string;
  image?: string;
  url?: string;
  type?: 'website' | 'article';
  pubDate?: Date;
}

const {
  title,
  description = "Vedhasagaran's Portfolio - Full Stack Developer & Software Engineer. Explore my projects, skills, and experience in web development.",
  image = ASSETS.ogImage,
  url = Astro.url.href,
  type = 'website',
  pubDate
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const isHome = Astro.url.pathname === '/';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- Primary Meta Tags -->
    <title>{title}</title>
    <meta name="title" content={title} />
    <meta name="description" content={description} />
    <meta name="author" content="Vedhasagaran" />
    <meta name="keywords" content="Vedhasagaran, portfolio, AI, developer, full stack, software engineer, web development, React, JavaScript, TypeScript" />
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content={type} />
    <meta property="og:url" content={url} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(image, Astro.site)} />
    <meta property="og:site_name" content="Vedhasagaran's Portfolio" />

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={url} />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={new URL(image, Astro.site)} />

    <meta name="google-site-verification" content="CePmeqytrkzWb20MT71VJuqPLlP8Bsn9xUK5cB4CTKQ" />

    <link rel="icon" type="image/jpeg" href={ASSETS.logos.light} />
    <link rel="apple-touch-icon" href={ASSETS.logos.light} />

    <!-- Preload critical images -->
    {isHome && <link rel="preload" as="image" href={ASSETS.profile} />}

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">

    <!-- JSON-LD Structured Data -->
    {type === 'article' ? (
      <script type="application/ld+json" set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "BlogPosting",
        "headline": title,
        "description": description,
        "image": new URL(image, Astro.site).href,
        "datePublished": pubDate ? pubDate.toISOString() : undefined,
        "author": {
          "@type": "Person",
          "name": "Vedhasagaran Mahalingam",
          "url": Astro.site ? Astro.site.href : url
        },
        "publisher": {
          "@type": "Organization",
          "name": "Vedhasagaran's Portfolio",
          "logo": {
            "@type": "ImageObject",
            "url": new URL(ASSETS.logos.light, Astro.site).href
          }
        },
        "mainEntityOfPage": {
          "@type": "WebPage",
          "@id": canonicalURL.href
        }
      })} />
    ) : (
      <script type="application/ld+json" set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "Person",
        "name": "Vedhasagaran Mahalingam",
        "url": url,
        "jobTitle": "Software Development Engineer",
        "description": "Software Development Engineer at PRO specializing in full stack development with expertise in C#, Node.js, Angular, React, and database technologies.",
        "knowsAbout": ["Full Stack Development", "C#", "Node.js", "Angular", "React", "SQL", "MongoDB", "Redis", "Web Development", "Software Engineering"],
        "worksFor": {
          "@type": "Organization",
          "name": "PRO"
        },
        "sameAs": ["https://www.linkedin.com/in/vedhasagaran-m/"]
      })} />
    )}

    <script is:inline define:vars={{ darkLogo: ASSETS.logos.dark, lightLogo: ASSETS.logos.light }}>
      (function() {
        const savedTheme = localStorage.getItem('theme');
        const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        const shouldBeDark = savedTheme === 'dark' || (!savedTheme && prefersDark);

        if (shouldBeDark) {
          document.documentElement.classList.add('dark');
        }

        const favicon = document.querySelector('link[rel="icon"]');
        if (favicon) {
          favicon.setAttribute('href', shouldBeDark ? darkLogo : lightLogo);
        }
        const appleIcon = document.querySelector('link[rel="apple-touch-icon"]');
        if (appleIcon) {
          appleIcon.setAttribute('href', shouldBeDark ? darkLogo : lightLogo);
        }
      })();

      document.addEventListener('astro:before-swap', (ev) => {
        const savedTheme = localStorage.getItem('theme');
        const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        const shouldBeDark = savedTheme === 'dark' || (!savedTheme && prefersDark);
        if (shouldBeDark) {
          ev.newDocument.documentElement.classList.add('dark');
        } else {
          ev.newDocument.documentElement.classList.remove('dark');
        }

        const favicon = ev.newDocument.querySelector('link[rel="icon"]');
        if (favicon) {
          favicon.setAttribute('href', shouldBeDark ? darkLogo : lightLogo);
        }
        const appleIcon = ev.newDocument.querySelector('link[rel="apple-touch-icon"]');
        if (appleIcon) {
          appleIcon.setAttribute('href', shouldBeDark ? darkLogo : lightLogo);
        }
      });
    </script>

    <script is:inline>
      (function() {
        let clickHistory = [];
        document.addEventListener("click", function(event) {
          const target = event.target;
          if (!target || target.nodeType !== 1) return;
          const interactive = target.closest("a, button, [role=button], input, label");
          if (!interactive) return;

          const now = Date.now();
          clickHistory.push({ t: now, el: interactive });
          clickHistory = clickHistory.filter(function(c) { return now - c.t <= 800; });

          const sameEl = clickHistory.filter(function(c) { return c.el === interactive; });
          if (sameEl.length >= 3) {
            console.warn("Rage click detected on", interactive);
            clickHistory = [];
          }
        }, { capture: true, passive: true });
      })();
    </script>


    <ClientRouter />
  </head>
  <body style="background-color: var(--background); color: var(--foreground); transition: background-color 0.3s, color 0.3s;">
    <slot />
    
    <!-- Lenis Smooth Scroll -->
    <script>
      import Lenis from 'lenis';

      let lenis: Lenis | null = null;

      document.addEventListener('astro:page-load', () => {
        if (lenis) {
          lenis.destroy();
        }
        lenis = new Lenis();
        function raf(time: number) {
          lenis?.raf(time);
          requestAnimationFrame(raf);
        }
        requestAnimationFrame(raf);
      });

      window.addEventListener('scroll', () => {
        const progress = document.getElementById('progress-bar');
        if (!progress) return;
        const totalHeight = document.documentElement.scrollHeight - window.innerHeight;
        const scrollPct = totalHeight > 0 ? (window.scrollY / totalHeight) * 100 : 0;
        progress.style.width = `${scrollPct}%`;
      }, { passive: true });
    </script>
  </body>
</html>